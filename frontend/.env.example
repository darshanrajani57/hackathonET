#############################################
# FintelOS Frontend Environment Template
# Copy this file to .env.local and fill values.
#############################################

#############################################
# Frontend runtime (safe for browser)
#############################################
NEXT_PUBLIC_USE_MOCK_DATA=true
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/market
NEXT_PUBLIC_DEFAULT_EXCHANGE=NSE
NEXT_PUBLIC_DEFAULT_TIMEZONE=Asia/Kolkata

#############################################
# Provider routing (server-side preference)
# Preferred values:
# - rapidapi_yahoo
# - rapidapi_twelvedata
# - direct_twelvedata
# - direct_alphavantage
#############################################
MARKET_DATA_PROVIDER=030be1b02emsh489ea2145392c88p1f5df7jsn4de78ae5a970
MARKET_DATA_FALLBACK_PROVIDER=2aae43f15d1a45e2b7a019825c1b2295

#############################################
# RapidAPI (server-side secret)
# IMPORTANT: Do NOT expose RAPIDAPI_KEY in browser code.
#############################################
RAPIDAPI_KEY=030be1b02emsh489ea2145392c88p1f5df7jsn4de78ae5a970
RAPIDAPI_HOST_YAHOO_FINANCE=yahoo-finance15.p.rapidapi.com
RAPIDAPI_HOST_TWELVEDATA= twelve-data1.p.rapidapi.com
RAPIDAPI_HOST_ALPHA_VANTAGE=alpha-vantage.p.rapidapi.com

#############################################
# Direct provider API keys (server-side)
#############################################
TWELVE_DATA_API_KEY=2aae43f15d1a45e2b7a019825c1b2295
ALPHA_VANTAGE_API_KEY=VUYMS5QCBLCRWYV9
FINNHUB_API_KEY=d74gdv9r01qno4q1lt60d74gdv9r01qno4q1lt6g
NEWS_API_KEY=deff8be33f694c9c97d909583c9811c7
FMP_API_KEY=3saEyE2uMTMvoT7aRumQz8owBWcIqyuD
MARKETSTACK_API_KEY=1493ba92d82a30068adb945afb087b39
EODHD_API_KEY=69c909bd4abcf8.17684129

#############################################
# India market/public-source ingestion (server-side)
#############################################
NSE_BASE_URL=https://www.nseindia.com
BSE_BASE_URL=https://www.bseindia.com
NSE_FII_DII_SOURCE_URL=https://www.nseindia.com/reports/fii-dii
NSE_IPO_SOURCE_URL=https://ipocentral.in/nse-ipo-news/

#############################################
# Request tuning (server-side)
#############################################
API_REQUEST_TIMEOUT_MS=12000
API_RETRY_COUNT=2
API_CACHE_TTL_SECONDS=30

#############################################
# Gemini AI chat backend (server-side secret)
#############################################
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

#############################################
# NVIDIA AI fallback backend (server-side secret)
#############################################
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.1-8b-instruct
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

#############################################
# Redis persistent memory (server-side)
#############################################
REDIS_URL=
REDIS_MEMORY_TTL_SECONDS=604800
REDIS_MEMORY_MAX_TURNS=40

#############################################
# Video Engine tuning
#############################################
NEXT_PUBLIC_VIDEO_ENGINE_ENABLED=true
VIDEO_ENGINE_AUTO_GENERATE=true
VIDEO_ENGINE_MIN_DURATION_SEC=30
VIDEO_ENGINE_MAX_DURATION_SEC=90
VIDEO_ENGINE_AUTO_INTERVAL_SEC=900
VIDEO_ENGINE_MAX_QUEUE=10
VIDEO_ENGINE_DEMO_URL=

#############################################
# Video render service contract (server-side)
#############################################
VIDEO_RENDER_API_BASE_URL=
VIDEO_RENDER_API_KEY=
VIDEO_RENDER_AUTH_HEADER=Authorization
VIDEO_RENDER_AUTH_SCHEME=Bearer
VIDEO_RENDER_SUBMIT_PATH=/v1/videos
VIDEO_RENDER_STATUS_PATH=/v1/videos/{jobId}
VIDEO_RENDER_POLL_INTERVAL_MS=2000
VIDEO_RENDER_POLL_TIMEOUT_MS=90000

#############################################
# Optional observability
#############################################
LOG_LEVEL=info
